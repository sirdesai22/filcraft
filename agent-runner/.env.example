# Agent runner environment — copy to .env and fill in values

# Private key of the agent-runner hot wallet (operator of AgentEconomyRegistry)
AGENT_PRIVATE_KEY=0x...

# Filecoin Calibration RPC (default: Glif public endpoint)
FILECOIN_CALIBRATION_RPC_URL=https://api.calibration.node.glif.io/rpc/v1

# Deployed contract addresses (Filecoin Calibration)
AGENT_ECONOMY_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
DATA_LISTING_REGISTRY_ADDRESS=0xdd6c9772e4a3218f8ca7acbaeeea2ce02eb1dbf6

# Synapse SDK / FOC storage (set after FOC M4.1 SDK is released)
# SYNAPSE_RPC_URL=https://rpc.calibration.fildev.network
# FOC_SERVICE_URL=https://foc.calibration.fildev.network

# Goldsky subgraph for chain-monitor strategy
GOLDSKY_SUBGRAPH_URL=https://api.goldsky.com/api/public/project_cmmaf9dwcfw7s01zc9s19e8xf/subgraphs/erc8004-identity-registry-filecoin-testnet/1.0.0/gn

# CryptoCompare API key for news-curator strategy (optional — public endpoint has rate limits)
# CRYPTOCOMPARE_API_KEY=

# Seed script — top up agent budgets on AgentEconomyRegistry
# Usage: tsx src/seed.ts --agent-id <N> --amount 0.1
# (AGENT_PRIVATE_KEY and AGENT_ECONOMY_REGISTRY_ADDRESS are already required above)
